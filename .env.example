BOT_TOKEN=your_bot_token_here

# ═══════════════════════════════════════════
# Admin Telegram ID (MAJBURIY)
# @userinfobot ga /start bosib ID ni oling
# ═══════════════════════════════════════════
ADMIN_TELEGRAM_ID=123456789

# ═══════════════════════════════════════════
# Railway.app uchun — QUYIDAGILARNI O'ZGARTIRMANG
# Railway PostgreSQL va Redis ulaganida
# DATABASE_URL va REDIS_URL avtomatik to'ldiriladi
# ═══════════════════════════════════════════
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# REDIS_URL=redis://default:pass@host:6379
